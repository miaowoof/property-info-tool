# ── Vacant to Vibrant Environment Variables ──────────────────────────────────
# Copy this file to .env for local development
# Set these same variables in Vercel dashboard under Settings → Environment Variables

# ATTOM Property Data API
# https://api.developer.attomdata.com/
VITE_ATTOM_API_KEY=your_attom_api_key_here

# RapidAPI key for LoopNet
# https://rapidapi.com/asyncsolutions-asyncsolutions-default/api/loopnet-api
RAPIDAPI_KEY=your_rapidapi_key_here

# App password — shared with your team
VITE_APP_PASSWORD=your_password_here
